{:paths ["src" "resources" "library"]

 :deps
 {org.clojure/clojure       {:mvn/version "1.12.0"}
  metosin/malli             {:mvn/version "0.16.3"}
  cheshire/cheshire         {:mvn/version "5.11.0"}
  http-kit/http-kit         {:mvn/version "2.8.1"}
  org.clojure/data.json     {:mvn/version "2.5.0"}
 com.cemerick/drawbridge   {:mvn/version "0.0.7"}
  ring/ring-core            {:mvn/version "1.11.0"}
  nrepl/nrepl               {:mvn/version "1.1.0"}
  org.clojure/tools.nrepl   {:mvn/version "0.2.13"}
  org.clojure/core.logic    {:mvn/version "1.1.0"}
  rewrite-clj/rewrite-clj   {:mvn/version "1.1.49"}

  ;; futon3b gate pipeline — social loop submits tasks through gates
  futon3b/futon3b           {:local/root "../futon3b"}

  ;; futon1b XTDB2 store — the substrate store (I-0 unification, 2026-07-14).
  ;; Brings XTDB 2.1.0 + the futon1b_server HTTP surface onto this classpath.
  ;; Replaces the retired futon1a/XTDB1 dep; futon3b's vestigial XTDB1 deps
  ;; were dropped in the same change so XTDB 1 and 2 (same Maven coordinate,
  ;; different major) don't collide. Served by the futon1b-server systemd unit
  ;; by default; embedded in-process when FUTON1B_EMBED=1 (see
  ;; dev/futon3c/dev/bootstrap.clj → start-futon1b-embedded!).
  futon1b/futon1b           {:local/root "../futon1b"}

  ;; futon0 — remaining shared tooling still consumed from futon3c.
  futon0/futon0             {:local/root "../futon0"}

  ;; futon2 — canonical War Machine engine + visualiser home.
  futon2/futon2             {:local/root "../futon2"}

  ;; futon3a — pattern retrieval + canonical flexiarg enrichment.
  ;; Exclusions (2026-07-14, I-0 unification): futon3a pulls graph-memory
  ;; (via nlp-interface) which uses XTDB **1.24.4** (xtdb-lmdb/-core/-rocksdb).
  ;; futon3c requires no futon3a namespace in-process (it's used out-of-process
  ;; via FUTON3A_ROOT), so graph-memory never loads in this JVM — but its
  ;; XTDB1 jars would otherwise sit on the classpath and clash with the
  ;; embedded futon1b XTDB **2** node (same com.xtdb/xtdb-core coordinate).
  ;; Excluding them keeps this JVM's classpath single-major (XTDB 2 only).
  futon3a/futon3a           {:local/root "../futon3a"
                             :exclusions [com.xtdb/xtdb-core
                                          com.xtdb/xtdb-lmdb
                                          com.xtdb/xtdb-rocksdb]}}

 :aliases
 {:test {:extra-paths ["test" "dev"]
         ;; Integration tests host the authoritative Futon1b/XTDB2 backend
         ;; in-process. Arrow requires the same module access and bounded
         ;; direct-memory settings as the serving JVM.
         :jvm-opts ["--add-opens=java.base/java.nio=org.apache.arrow.memory.core,ALL-UNNAMED"
                    "-Dio.netty.tryReflectionSetAccessible=true"
                    "-Djava.net.preferIPv4Stack=true"
                    "-Xmx2g" "-XX:MaxDirectMemorySize=768m"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/url "https://github.com/cognitect-labs/test-runner.git"
                       :sha "5e91ee0989d93115cfb5e15b6f242f5ec7ab762e"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test
         :exec-args {:dirs ["test"]}}

  :dev {:extra-paths ["dev"]
        ;; JVM opts for the one serving JVM (I-0). The Arrow --add-opens +
        ;; netty/pgwire flags are required for the embedded futon1b XTDB 2
        ;; node (FUTON1B_EMBED=1); harmless when it isn't embedded. These are
        ;; correctness flags and apply on every host, so they live here.
        ;;
        ;; HEAP SIZING IS DELIBERATELY NOT HERE. It is host-specific (the 3.8G
        ;; Linode and a laptop want different numbers), and a shared alias is
        ;; the one place two hosts cannot disagree without conflicting on every
        ;; pull. Sizing is passed as -J flags by the launcher and defaulted in
        ;; the Makefile (FUTON3C_HEAP / FUTON3C_DIRECT); each host overrides in
        ;; its own scripts/dev-<host>-env, which are separate committed files.
        :jvm-opts ["--add-opens=java.base/java.nio=org.apache.arrow.memory.core,ALL-UNNAMED"
                   "-Dio.netty.tryReflectionSetAccessible=true"
                   "-Djava.net.preferIPv4Stack=true"]
        :extra-deps {futon5/futon5 {:local/root "../futon5"}
                     webarxana/webarxana {:local/root "../futon4/dev/web/webarxana"}
                     ;; war-machine CLJS source must be on the JVM classpath
                     ;; (not just listed in shadow-cljs.edn :source-paths) for
                     ;; the embedded shadow-cljs server to index it. webarxana
                     ;; is already loaded as a local/root for the same reason.
                     war-machine/war-machine {:local/root "../futon2/web/war-machine"}
                     ;; Embedded shadow-cljs so CLJS watches run inside the
                     ;; futon3c JVM instead of spawning standalone npx
                     ;; processes (CLAUDE.md I-0: one JVM at rest).
                     ;; Driven via futon3c.dev.shadow + M-x start-shadow /
                     ;; stop-shadow. Version pinned to match the per-app
                     ;; package.json files (war-machine + webarxana).
                     thheller/shadow-cljs {:mvn/version "2.28.20"}
                     ;; CLJS compile-time deps for the embedded shadow-cljs
                     ;; builds. Standalone shadow-cljs reads these from its
                     ;; own :dependencies in shadow-cljs.edn; the embedded
                     ;; server uses the host JVM classpath, so the same
                     ;; jars must be declared here. Versions match the
                     ;; per-app shadow-cljs.edn :dependencies.
                     reagent/reagent       {:mvn/version "1.2.0"}
                     cljs-http/cljs-http   {:mvn/version "0.1.46"}
                     datascript/datascript {:mvn/version "1.7.3"}}
        :main-opts ["-m" "futon3c.dev"]}

  :repl {:main-opts ["-m" "nrepl.cmdline"
                     "--middleware" "[cider.nrepl/cider-middleware]"]
         :extra-deps {nrepl/nrepl {:mvn/version "1.1.1"}
                      cider/cider-nrepl {:mvn/version "0.47.1"}}}}}
