unlocks #{}, :artifact-paths []}}, :current-mode :FALSIFY, :problem-id "FM-001", :canonical {:statement "Given n, construct a graph G on 4n-2 vertices such that G contains no copy of B_{n-1} and the complement of G contains no copy of B_n, where B_k is the triangular book graph on k+2 vertices (k pages sharing a common K_2 edge). This witnesses R(B_{n-1}, B_n) >= 4n-1, proving the Rousseau-Sheehan upper bound sharp. Output: binary adjacency string, column-major order. Tiers: (T1) n=25, 98 vertices; (T2) n=50, 198 vertices; (T3) general algorithm for all n, under 10 minutes for n<=100.", :closure-criterion "Either (a) produce a general algorithm solving T3, or (b) solve T1 and/or T2 with explicit constructions, or (c) identify a named structural obstruction proving no general construction exists.", :statement-hash "sha256:7c1b69591e101dfd5f0a9263a15ec04c06b3331d83a67339546c33604e32c322", :version-history [{:version 0, :statement "Pending formal spec-lock. Source: epoch.ai/frontiermath/open-problems", :hash "sha256:pending-spec-lock", :changed-at "2026-02-20T00:00:00Z", :reason "Initial bootstrap from futon6 FM-001 problem state"} {:version 1, :statement "Given n, construct a graph G on 4n-2 vertices such that G contains no copy of B_{n-1} and the complement of G contains no copy of B_n, where B_k is the triangular book graph on k+2 vertices (k pages sharing a common K_2 edge). This witnesses R(B_{n-1}, B_n) >= 4n-1, proving the Rousseau-Sheehan upper bound sharp. Output: binary adjacency string, column-major order. Tiers: (T1) n=25, 98 vertices; (T2) n=50, 198 vertices; (T3) general algorithm for all n, under 10 minutes for n<=100.", :hash "sha256:7c1b69591e101dfd5f0a9263a15ec04c06b3331d83a67339546c33604e32c322", :changed-at "2026-02-21T16:56:28Z", :reason "Spec correction: actual FrontierMath problem is off-diagonal construction R(B_{n-1},B_n). Added tiers, output format, runtime constraint."}]}, :version 12, :tryharder-log [], :failed-routes []}