{:proof/conjecture-tests [{:id "H-F1-n5", :conjecture "H-F1", :parameter {:n 5}, :outcome :refuted, :method "kissat 4.0.4 --time=1800", :timestamp "2026-03-09T16:05:00Z", :artifacts ["futon6/data/frontiermath-pilot/harness/FM001-n5.kissat.log" "futon6/data/frontiermath-pilot/harness/n5-witness.json"]}], :proof/updated-at "2026-03-10T12:30:40.215958721Z", :proof/falsify-completed? true, :proof/cycles [], :proof/ledger {"C3-verify-G" {:item/id "C3-verify-G", :item/label "B_{n-1}-freeness checker for candidate graph G", :item/status :numerically-verified, :item/depends-on #{"C2-strategy"}, :item/unlocks #{"T2-single" "T1-warm" "T3-general"}, :item/artifact-paths []}, "T2-single" {:item/id "T2-single", :item/label "Tier 2: n=50 witness (198 vertices), adjacency string output", :item/status :open, :item/depends-on #{"C3-verify-G" "C4-verify-complement"}, :item/unlocks #{}, :item/artifact-paths []}, "C4-verify-complement" {:item/id "C4-verify-complement", :item/label "B_n-freeness checker for complement of G", :item/status :numerically-verified, :item/depends-on #{"C2-strategy"}, :item/unlocks #{"T2-single" "T1-warm" "T3-general"}, :item/artifact-paths []}, "C2-strategy" {:item/id "C2-strategy", :item/label "Construction strategy: algebraic (Paley/Cayley), random, or hybrid", :item/status :proved, :item/depends-on #{"C1-structure"}, :item/unlocks #{"C3-verify-G" "C4-verify-complement"}, :item/artifact-paths [], :item/heuristics [{:status :active, :type :analogy, :content "Paley graph for n=25 since q=49=7^2 is prime power with q=1(mod 4)", :by "claude-2", :recorded-at "2026-03-08T18:56:45.430391056Z"} {:status :superseded, :type :strategy-shift, :content "SAT infeasible at scale — pivot to algebraic constructions (Cayley/Paley)", :by "claude-2", :recorded-at "2026-03-08T18:56:45.433091188Z", :superseded-by "Wesley 2-block-circulant resolves construction"} {:status :superseded, :type :decomposition, :content "[SUPERSEDED] Paley(97)+inf tightness analysis — moot after Wesley 2-block-circulant", :by "claude-2", :recorded-at "2026-03-09T01:45:08.669864264Z"} {:status :superseded, :type :specialization, :content "[SUPERSEDED] |S| tuning lever — moot after Wesley 2-block-circulant", :by "claude-2", :recorded-at "2026-03-09T01:45:08.674323200Z"} {:status :superseded, :type :strategy-shift, :content "[SUPERSEDED] Extended Paley S=QR refuted, Cayley Z_98 path — moot after Wesley", :by "claude-2", :recorded-at "2026-03-09T02:48:56.309920599Z"} {:status :superseded, :type :decomposition, :content "[SUPERSEDED] Approach eval (Cayley Z_98 vs extension) — moot after Wesley", :by "claude-2", :recorded-at "2026-03-09T02:54:31.382561930Z"} {:status :superseded, :type :strategy-shift, :content "[SUPERSEDED] All pre-Wesley approaches failed pivot — resolved by Wesley", :by "claude-2", :recorded-at "2026-03-09T03:15:21.198946375Z"} {:status :active, :type :related-problem, :content "BREAKTHROUGH: Wesley 2025 (arXiv:2410.03625v2) proves R(B_{n-1},B_n)=4n-1 for infinite family using 2-BLOCK-circulant graph (not 1-block Cayley!). Key insight: two copies of F_q with asymmetric QR/NR rules trade G-freeness against complement-freeness across blocks. Computationally verified for n=25.", :by "claude-2", :recorded-at "2026-03-09T03:41:04.329670135Z"} {:status :active, :type :pattern-use, :content "Construction FOUND via literature (Wesley 2025). Mode transition CONSTRUCT->VERIFY appropriate. Remaining: (1) write up formal proof for FM-001, (2) verify T2 (n=50, q=99 — q mod 4=3, needs different approach for n=50).", :by "claude-2", :recorded-at "2026-03-09T03:41:04.357032221Z"}], :item/conjectures [{:id "H-C2-cayley-qr-embed", :hypothesis "QR(97) embedded as connection set in Z_98 gives valid Ramsey witness. Cayley(Z_98, QR(97)) should have max common neighbors < 24 (B_24-free) and complement max CN < 25 (B_25-free), since Paley(97) has lambda=23 and the extra vertex is absorbed into the cyclic structure.", :status :refuted, :tests [{:method "direct computation", :outcome :refuted, :tested-at "2026-03-09T03:15:21.052868681Z", :params {:connection-set "QR(97) in Z_98", :max-G-CN 27, :max-comp-CN 28, :issue "QR(97) not symmetric mod 98"}, :evidence-ref "QR(97) symmetric mod 97 not mod 98. G-edge max CN=27 (need <24). SA search also failed: best score 5 (CN=26).", :agent "claude-2"}], :refinements [], :created-at "2026-03-09T02:54:31.221460225Z"} {:id "H-C2-wesley-2block", :hypothesis "Wesley 2-block-circulant construction: Gamma_{F_q}(Q,Q,N) on 2q=4n-2 vertices with D11=D12=QR, D22=NR gives (B_{n-1},B_n)-free graph when q=2n-1 is prime power equiv 1 mod 4. Max G-CN = n-2 < n-1, max comp-CN = n-1 < n.", :status :confirmed, :tests [{:method "computational verification on GF(49)", :outcome :confirmed, :tested-at "2026-03-09T03:41:04.301095072Z", :params {:q 49, :n 25, :field "GF(49)=F7[x]/(x^2+1)", :max-G-CN 23, :max-comp-CN 24}, :evidence-ref "Wesley arXiv:2410.03625v2 Theorem 2. Verified: max G-CN=23<24 (B24-free), max comp-CN=24<25 (B25-free). R(B24,B25)=99.", :agent "claude-2"}], :refinements [], :created-at "2026-03-09T03:41:04.208768935Z"}]}, "C1-structure" {:item/id "C1-structure", :item/label "Characterize B_k-freeness: max common-edge neighborhoods in G", :item/status :proved, :item/depends-on #{"F2-literature"}, :item/unlocks #{"C2-strategy"}, :item/artifact-paths [], :item/heuristics [{:status :active, :type :decomposition, :content "B_k-freeness reduces to: for every edge uv, |N(u) ∩ N(v)| < k. In Paley(q) (strongly regular), lambda = (q-5)/4 is the EXACT common-neighbor count for all edges. So Paley(q) is B_k-free iff (q-5)/4 < k, i.e., q < 4k+5.", :by "claude-2", :recorded-at "2026-03-09T01:41:49.684885534Z"} {:status :active, :type :specialization, :content "For q=4n-3 (prime equiv 1 mod 4): Paley(q) has lambda=(4n-8)/4=n-2. B_{n-1}-freeness needs lambda < n-1. Since n-2 < n-1: check. Complement (self-complementary, same lambda): B_n-freeness needs lambda < n. Since n-2 < n: check. So Paley(4n-3) IS the right witness — on q vertices, not q+1.", :by "claude-2", :recorded-at "2026-03-09T01:41:49.688686800Z"} {:status :superseded, :type :dead-end, :content "[SUPERSEDED] S=QR twin obstruction — moot after Wesley 2-block-circulant", :by "claude-2", :recorded-at "2026-03-09T02:48:47.680542453Z"} {:status :superseded, :type :dead-end, :content "[SUPERSEDED] Extension approach fragility analysis — resolved by Wesley", :by "claude-2", :recorded-at "2026-03-09T02:54:31.413167396Z"} {:status :superseded, :type :dead-end, :content "[SUPERSEDED] Duplicate of above extension fragility note", :by "claude-2", :recorded-at "2026-03-09T02:55:05.017069775Z"} {:status :superseded, :type :dead-end, :content "[SUPERSEDED] Paley+inf impossibility proof — resolved by Wesley (no extension needed)", :by "claude-2", :recorded-at "2026-03-09T03:15:21.166753125Z"}], :item/conjectures [{:id "H-C1-extended-paley", :hypothesis "Extended Paley construction: Paley(q) + one vertex ∞ adjacent to all QRs. The new vertex ∞ has degree (q-1)/2 and common-neighbor count with each neighbor ≈ (q-5)/4 = n-2. Since n-2 < n-1, the extended graph should be B_{n-1}-free. But exact counts vary per vertex — needs computational verification for q=97 (n=25) and q=197 (n=50).", :status :refuted, :tests [{:method "exact analysis", :outcome :refuted, :tested-at "2026-03-09T02:48:42.974063473Z", :params {:construction "Paley97+QR", :issue "twin-obstruction"}, :evidence-ref "vertex 0 and inf are twins: complement edge (0,inf) has 48 common neighbors, violating B25-freeness. All other complement edges OK (24 < 25).", :agent "claude-2"}], :refinements [], :created-at "2026-03-09T01:41:49.691768695Z"} {:id "H-C1-cayley-alternative", :hypothesis "Alternative: Cayley graph on Z_{4n-2} with connection set C = {c : c is QR mod p for some auxiliary prime p dividing 4n-2, or c satisfies a quadratic criterion}. Avoids the extension problem entirely by working on the right number of vertices from the start.", :status :refuted, :tests [{:method "SA search + SRG analysis", :outcome :refuted, :tested-at "2026-03-09T03:15:21.137279836Z", :params {:group "Z_98", :best-score 5, :best-max-G 26, :issue "No srg(98,k,<=23,mu) exists; search failed"}, :evidence-ref "20 SA restarts x 50K steps, best CN=26. SRG(98,k,lambda,mu) impossible: 97 prime forces 97|k or 97|mu, no solutions with lambda<=23.", :agent "claude-2"}], :refinements [], :created-at "2026-03-09T01:41:49.695595651Z"}]}, "F2-literature" {:item/id "F2-literature", :item/label "Literature search: existing constructions or impossibility results for book graph Ramsey", :item/status :proved, :item/depends-on #{"F1-opposite"}, :item/unlocks #{"C1-structure"}, :item/artifact-paths [], :item/conjectures [{:id "H-F2-goodness", :hypothesis "Book graphs B_n are Ramsey-good: R(B_n, K_m) = (n-1)(m-1)+1 for m sufficiently large. Established by Nikiforov-Rousseau (2005). Does not directly give R(B_{n-1}, B_n).", :status :untested} {:id "H-F2-offbyone", :hypothesis "Paley(q) gives q vertices but we need 4n-2. The off-by-one is resolved by Wesley 2-block-circulant which constructs on 2q = 4n-2 vertices directly.", :status :resolved, :resolution "Wesley 2-block-circulant avoids the extension entirely. Two copies of F_q give 2q=4n-2 vertices."}], :item/heuristics [{:status :active, :refs [], :recorded-at "2026-03-09T01:39:09.435557446Z", :type :related-problem, :content "Rousseau-Sheehan (1978): R(B_{n-1}, B_n) <= 4n-1. The upper bound comes from a counting argument on common neighborhoods of the shared edge. The problem asks us to show this is TIGHT by constructing a witness on 4n-2 vertices.", :by "claude-2"} {:status :active, :refs [], :recorded-at "2026-03-09T01:39:09.437767128Z", :type :analogy, :content "Paley graphs are the classical tool for Ramsey lower bounds. Paley(q) for prime power q ≡ 1 (mod 4) is self-complementary, strongly regular with parameters (q, (q-1)/2, (q-5)/4, (q-1)/4). For n=25: need 98 vertices, so q=97 (prime, 97≡1 mod 4) gives Paley(97) — a self-complementary graph on 97 vertices. One vertex short of 98. For n=50: need 198 vertices, q=197 (prime, 197≡1 mod 4) gives Paley(197) on 197 vertices. One short again.", :by "claude-2"} {:status :active, :refs [], :recorded-at "2026-03-09T01:39:09.444041549Z", :type :related-problem, :content "Small cases known: R(B_1,B_2)=7 (triangles), R(B_2,B_3)=11, R(B_3,B_4)=15 — all matching 4n-1 bound. These are the n=2,3,4 cases that our SAT confirmed. The pattern 4n-1 being tight for all small n strongly suggests a general construction exists.", :by "claude-2"} {:status :active, :refs [], :recorded-at "2026-03-09T01:39:09.446560675Z", :type :related-problem, :content "Nikiforov (2011) extended Ramsey goodness theory and showed various graph families have predictable Ramsey behavior. Key technique: bounding independence numbers and using Turán-type results. For book graphs specifically, the max-triangle-free subgraph and complement structure are the critical invariants.", :by "claude-2"}]}, "T1-warm" {:item/id "T1-warm", :item/label "Tier 1: n=25 witness (98 vertices), adjacency string output", :item/status :numerically-verified, :item/depends-on #{"C3-verify-G" "C4-verify-complement"}, :item/unlocks #{}, :item/artifact-paths []}, "F1-opposite" {:item/artifact-paths [], :item/evidence-type :numerical, :item/id "F1-opposite", :item/heuristics [{:status :active, :refs [], :recorded-at "2026-03-08T18:56:45.424593787Z", :type :simplification, :content "Test small cases n=3,4 before tackling n=25", :by "codex"} {:status :active, :refs [], :recorded-at "2026-03-08T18:56:45.427902608Z", :type :dead-end, :content "SAT encoding infeasible for n>=5 (solver timeout)", :by "codex"} {:status :active, :refs [], :recorded-at "2026-03-08T21:30:46.238875360Z", :type :strategy-shift, :content "SAT exhausted for F1. Three manual paths: (1) probabilistic argument — show random G on 4n-2 vertices has positive probability of being B_{n-1}-free with B_n-free complement, proving witnesses exist for all n. (2) Algebraic witness for n=5 — construct G directly from Paley(17) or Cayley(Z_17), verify B_4-freeness and complement B_5-freeness by hand. (3) Close F1 as sufficiently-tested — n=3,4 witnesses confirm the pattern, SAT infeasible beyond that; transition to F2-literature and the construction path.", :by "claude-2"}], :item/label "Falsification attempt: evidence R(B_{n-1},B_n) < 4n-1 for some n", :item/status :numerically-verified, :item/depends-on #{}, :item/conjectures [{:id "H-F1", :hypothesis "There exists n such that R(B_{n-1},B_n) < 4n-1 (the Rousseau-Sheehan bound is not tight)", :status :partially-tested, :tests [{:method "SAT encoding", :outcome :refuted, :tested-at "2026-03-08T18:32:18.721341578Z", :params {:n 4, :vertices 14}, :evidence-ref "futon6:/tmp/fm001-n4.json (witness: 14-vertex graph, B_3-free, complement B_4-free)", :agent "codex"} {:method "SAT encoding", :outcome :refuted, :tested-at "2026-03-08T18:32:43.141062878Z", :params {:n 3, :vertices 10}, :evidence-ref "futon6:/tmp/fm001-n3.json", :agent "codex"} {:method "SAT encoding", :outcome :refuted, :tested-at "2026-03-08T18:32:43.144532931Z", :params {:n 4, :vertices 14}, :evidence-ref "futon6:/tmp/fm001-n4.json", :agent "codex"} {:method "SAT encoding", :outcome :inconclusive, :tested-at "2026-03-08T18:32:43.147154621Z", :params {:n 5, :vertices 18}, :evidence-ref "futon6:/tmp/FM001-n5.cnf.gz (infeasible — solver timeout)", :agent "codex"}], :refinements [], :created-at "2026-03-08T18:31:56.751057987Z"}], :item/unlocks #{"F2-literature"}}, "T3-general" {:item/id "T3-general", :item/label "Tier 3: general algorithm for all n, <10min for n<=100", :item/status :open, :item/depends-on #{"C3-verify-G" "C4-verify-complement"}, :item/unlocks #{}, :item/artifact-paths []}}, :proof/current-mode :MAP, :proof/problem-id "FM-001", :proof/canonical {:statement "Given n, construct a graph G on 4n-2 vertices such that G contains no copy of B_{n-1} and the complement of G contains no copy of B_n, where B_k is the triangular book graph on k+2 vertices (k pages sharing a common K_2 edge). This witnesses R(B_{n-1}, B_n) >= 4n-1, proving the Rousseau-Sheehan upper bound sharp. Output: binary adjacency string, column-major order. Tiers: (T1) n=25, 98 vertices; (T2) n=50, 198 vertices; (T3) general algorithm for all n, under 10 minutes for n<=100.", :closure-criterion "Either (a) produce a general algorithm solving T3, or (b) solve T1 and/or T2 with explicit constructions, or (c) identify a named structural obstruction proving no general construction exists.", :statement-hash "sha256:7c1b69591e101dfd5f0a9263a15ec04c06b3331d83a67339546c33604e32c322", :version-history [{:version 0, :statement "Pending formal spec-lock. Source: epoch.ai/frontiermath/open-problems", :hash "sha256:pending-spec-lock", :changed-at "2026-02-20T00:00:00Z", :reason "Initial bootstrap from futon6 FM-001 problem state"} {:version 1, :statement "Given n, construct a graph G on 4n-2 vertices such that G contains no copy of B_{n-1} and the complement of G contains no copy of B_n, where B_k is the triangular book graph on k+2 vertices (k pages sharing a common K_2 edge). This witnesses R(B_{n-1}, B_n) >= 4n-1, proving the Rousseau-Sheehan upper bound sharp. Output: binary adjacency string, column-major order. Tiers: (T1) n=25, 98 vertices; (T2) n=50, 198 vertices; (T3) general algorithm for all n, under 10 minutes for n<=100.", :hash "sha256:7c1b69591e101dfd5f0a9263a15ec04c06b3331d83a67339546c33604e32c322", :changed-at "2026-02-21T16:56:28Z", :reason "Spec correction: actual FrontierMath problem is off-diagonal construction R(B_{n-1},B_n). Added tiers, output format, runtime constraint."}]}, :proof/version 68, :proof/tryharder-log [], :proof/failed-routes []}