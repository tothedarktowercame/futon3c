 {:id :P-measure-restrict-simplify
  :name "Simplify μ(univ) for restricted measures"
  :recognition "Working with volume.restrict on [0,1] → rewrite μ(univ) = volume(Icc 0 1) = 1 to collapse rpow and mul terms"
  :mathlib-api ["Measure.restrict_apply" "Real.volume_Icc" "ENNReal.ofReal_one" "one_rpow" "mul_one"]
  :tactic-chain ["rw [Measure.restrict_apply]" "rw [Real.volume_Icc]" "rw [one_rpow, mul_one]"]
  :subjects [:analysis]
  :examples ["a00J01"]
  :difficulty :routine}

 {:id :P-rpow-exponent-limit
  :name "Limit of t^{1/n} → 1 via continuity"
  :recognition "Need t^{1/p} → 1 as p → ∞ for fixed t > 0 → compose Real.continuousAt_const_rpow with tendsto_const_div_atTop_nhds_zero_nat"
  :mathlib-api ["Real.continuousAt_const_rpow" "Real.rpow_zero" "tendsto_const_div_atTop_nhds_zero_nat"]
  :tactic-chain ["have hcont := Real.continuousAt_const_rpow" "have hlim := tendsto_const_div_atTop_nhds_zero_nat" "exact hcont.tendsto.comp hlim"]
  :subjects [:analysis]
  :examples ["a00J01"]
  :difficulty :moderate}

