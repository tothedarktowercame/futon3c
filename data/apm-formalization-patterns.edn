;; APM Formalization Pattern Library — extracted from 19 proved + 2 partial overnight proofs
;; Generated 2026-04-01 from ApmCanaries/Frames/*/Main.lean
;;
;; Each pattern has:
;;   :id           — unique pattern identifier
;;   :name         — human-readable name
;;   :recognition  — when to reach for this pattern (the informal dependency)
;;   :mathlib-api  — key Mathlib lemmas/APIs used
;;   :tactic-chain — typical tactic sequence
;;   :subjects     — which prelim subjects use it
;;   :examples     — problems where this pattern succeeded
;;   :difficulty   — :routine / :moderate / :hard

[
 {:id :P-connected-union
  :name "Connected union via common point"
  :recognition "Union of connected sets sharing a common point → argue by contradiction via separations, each connected piece stays on one side"
  :mathlib-api ["isPreconnected_sUnion" "Set.range" "Set.not_nonempty_iff"]
  :tactic-chain ["classical" "by_cases" "simpa [sUnion_range]"]
  :subjects [:topology]
  :examples ["t92J01"]
  :difficulty :routine}

 {:id :P-separation-function
  :name "Continuous separation function from distance"
  :recognition "Separate disjoint closed sets by a continuous [0,1]-valued function → use dist(x,A)/(dist(x,A)+dist(x,B)) with empty-set guard"
  :mathlib-api ["Metric.continuous_infDist_pt" "Metric.infDist_nonneg" "Continuous.div" "Set.nonempty_iff_ne_empty"]
  :tactic-chain ["have" "exact" "simp" "ext" "classical"]
  :subjects [:topology]
  :examples ["t94A02"]
  :difficulty :moderate}

