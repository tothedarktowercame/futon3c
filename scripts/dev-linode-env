#!/usr/bin/env bash
set -euo pipefail

# Linode authority profile for futon3c dev.
# Just run: ./scripts/dev-linode-env
#
# All role-specific knowledge is baked in. Override env vars only if
# you know what you're doing.

# --- Role & network ---
export FUTON3C_ROLE="${FUTON3C_ROLE:-linode}"
export FUTON3C_BIND_HOST="${FUTON3C_BIND_HOST:-0.0.0.0}"
export FUTON3C_PORT="${FUTON3C_PORT:-7070}"
export FUTON3C_SELF_URL="${FUTON3C_SELF_URL:-http://172.236.28.208:7070}"

# --- IRC: ngircd runs externally; built-in IRC disabled ---
export FUTON3C_IRC_PORT="${FUTON3C_IRC_PORT:-0}"

# --- Agents: Claude runs here, Codex runs on laptop ---
# Claude-1 lives on workspace1 (its blackboard goes there)
export CLAUDE_EMACS_SOCKET="${CLAUDE_EMACS_SOCKET:-workspace1}"
export FUTON3C_REGISTER_CLAUDE="${FUTON3C_REGISTER_CLAUDE:-true}"
export FUTON3C_REGISTER_CODEX="${FUTON3C_REGISTER_CODEX:-false}"
export FUTON3C_RELAY_CODEX="${FUTON3C_RELAY_CODEX:-true}"

# --- Codex settings (for relay/proxy, not local execution) ---
export CODEX_SANDBOX="${CODEX_SANDBOX:-danger-full-access}"
export CODEX_APPROVAL="${CODEX_APPROVAL:-never}"
export CODEX_APPROVAL_POLICY="${CODEX_APPROVAL_POLICY:-${CODEX_APPROVAL}}"

# --- Futon1a/Futon4 compatibility ---
export FUTON1A_PORT="${FUTON1A_PORT:-7071}"
export FUTON1A_STATIC_DIR="${FUTON1A_STATIC_DIR:-${HOME}/code/futon4/dev/web}"
export FUTON1A_COMPAT_PENHOLDER="${FUTON1A_COMPAT_PENHOLDER:-api}"
if [[ -z "${FUTON1A_ALLOWED_PENHOLDERS:-}" ]]; then
  export FUTON1A_ALLOWED_PENHOLDERS="${FUTON1A_COMPAT_PENHOLDER}"
elif [[ ",${FUTON1A_ALLOWED_PENHOLDERS}," != *",${FUTON1A_COMPAT_PENHOLDER},"* ]]; then
  export FUTON1A_ALLOWED_PENHOLDERS="${FUTON1A_ALLOWED_PENHOLDERS},${FUTON1A_COMPAT_PENHOLDER}"
fi
export FUTON4_BASE_URL="${FUTON4_BASE_URL:-http://localhost:${FUTON1A_PORT}/api/alpha}"
export FUTON4_PENHOLDER="${FUTON4_PENHOLDER:-${FUTON1A_COMPAT_PENHOLDER}}"
export FUTON4_ENABLE_SYNC="${FUTON4_ENABLE_SYNC:-1}"

# --- Federation: auto-peer with laptop if URL provided ---
if [[ -n "${FUTON3C_LAPTOP_URL:-}" && -z "${FUTON3C_PEERS:-}" ]]; then
  export FUTON3C_PEERS="${FUTON3C_LAPTOP_URL}"
fi

# --- Emacs daemon socket auto-detection (for blackboard) ---
if [[ -z "${FUTON3C_EMACS_SOCKET:-}" ]]; then
  _emacs_dir="/run/user/$(id -u)/emacs"
  if [[ -d "$_emacs_dir" ]]; then
    _sockets=("$_emacs_dir"/*)
    if [[ ${#_sockets[@]} -eq 1 && -S "${_sockets[0]}" ]]; then
      export FUTON3C_EMACS_SOCKET="$(basename "${_sockets[0]}")"
    elif [[ ${#_sockets[@]} -gt 1 ]]; then
      # Multiple daemons — pick the most recently modified socket
      _newest="$(ls -t "$_emacs_dir" | head -1)"
      if [[ -n "$_newest" ]]; then
        export FUTON3C_EMACS_SOCKET="$_newest"
      fi
    fi
  fi
  if [[ -n "${FUTON3C_EMACS_SOCKET:-}" ]]; then
    echo "[dev] Emacs socket: ${FUTON3C_EMACS_SOCKET}"
  fi
fi

# --- IRC infrastructure health check ---
if systemctl is-active ngircd.service >/dev/null 2>&1; then
  echo "[dev] ngircd: running"
else
  echo -e "[dev] \033[1;31m██ ngircd: DOWN ██\033[0m"
  echo -e "[dev] \033[31m   restart with: sudo systemctl restart ngircd\033[0m"
fi

# Check all bridge instances (template units: ngircd-bridge@channel.service)
_any_bridge=false
for _envfile in /home/joe/.config/futon3c/bridge-*.env; do
  [[ -f "$_envfile" ]] || continue
  _chan=$(basename "$_envfile" .env)
  _chan=${_chan#bridge-}
  if systemctl --user is-active "ngircd-bridge@${_chan}.service" >/dev/null 2>&1; then
    echo "[dev] ngircd bridge #${_chan}: running"
    _any_bridge=true
  else
    echo -e "[dev] \033[1;31m██ ngircd bridge #${_chan}: DOWN ██\033[0m"
    echo -e "[dev] \033[31m   restart with: systemctl --user restart ngircd-bridge@${_chan}\033[0m"
  fi
done
if [[ "$_any_bridge" != "true" ]]; then
  # Also check legacy single service and orphan processes
  if systemctl --user is-active ngircd-bridge.service >/dev/null 2>&1; then
    echo -e "[dev] \033[33mngircd bridge: running (legacy unit — migrate to template)\033[0m"
  elif pgrep -f ngircd_bridge.py >/dev/null 2>&1; then
    echo -e "[dev] \033[33mngircd bridge: running outside systemd (orphan?)\033[0m"
  else
    echo -e "[dev] \033[1;31m██ ngircd bridge: no bridges running ██\033[0m"
  fi
fi

exec make dev "$@"
