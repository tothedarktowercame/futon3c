#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/home/joe/code/futon3c/scripts/emacs-socket-lib.sh
source "${script_dir}/emacs-socket-lib.sh"

# Linode authority profile for futon3c dev.
# Just run: ./scripts/dev-linode-env
#
# All role-specific knowledge is baked in. Override env vars only if
# you know what you're doing.

# --- JVM sizing (host-specific: lucy is a 3.8G box) ---
# This box is RAM-bound, so the numbers are a constraint, not a preference.
# 2g heap + 768m direct + Arrow native + JVM overhead ran ~3.2G resident here
# (already ~850M into swap): a FUTON1B_EMBED=1 run swap-thrashed until the
# in-process :7074 evidence query blew its 120s idle timeout ("futon1b
# unreachable") and the OOM killer reaped `make dev` (2026-07-14). 1536m/640m
# is ~2.4G resident, which keeps swap as backstop rather than working set.
# Raise only if lucy gains RAM. Other hosts set their own in their own env file.
export FUTON3C_HEAP="${FUTON3C_HEAP:-1536m}"
export FUTON3C_DIRECT="${FUTON3C_DIRECT:-640m}"

# --- Role & network ---
export FUTON3C_ROLE="${FUTON3C_ROLE:-linode}"
# Site code: prefixes this box's locally-registered agent ids (lon-claude-1)
# so federated peers can mirror them. lucy = London.
export FUTON3C_SITE="${FUTON3C_SITE:-lon}"
export FUTON3C_BIND_HOST="${FUTON3C_BIND_HOST:-0.0.0.0}"
export FUTON3C_PORT="${FUTON3C_PORT:-7070}"
export FUTON3C_SELF_URL="${FUTON3C_SELF_URL:-http://172.236.28.208:7070}"

# --- IRC: ngircd runs externally; built-in IRC disabled ---
export FUTON3C_IRC_PORT="${FUTON3C_IRC_PORT:-0}"

# --- Agents: Claude runs here, Codex runs on laptop ---
# Unified Emacs: claude-1's blackboard falls back to FUTON3C_EMACS_SOCKET
# (the single futon-ops daemon, as on the laptop). Leave CLAUDE_EMACS_SOCKET
# unset unless you deliberately want a separate daemon. Any interactive Emacs
# can keep the default "server" socket.
export FUTON3C_REGISTER_CLAUDE="${FUTON3C_REGISTER_CLAUDE:-true}"
export FUTON3C_REGISTER_CODEX="${FUTON3C_REGISTER_CODEX:-false}"
export FUTON3C_RELAY_CODEX="${FUTON3C_RELAY_CODEX:-true}"

# Parked-on continuations (README-park.md): agents park a turn on dispatched
# work and self-resume when it lands. Enabled by default on lucy since
# 2026-07-11 (Joe); was also switched on live via System/setProperty that day.
export FUTON3C_PARKED_ON="${FUTON3C_PARKED_ON:-1}"

# claude CLI lives in ~/.local/bin here, which isn't on the JVM's
# non-interactive launch PATH — point CLAUDE_BIN at the absolute path so the
# local claude agent (lon-claude-1) is invocable.
export CLAUDE_BIN="${CLAUDE_BIN:-/home/joe/.local/bin/claude}"

# --- Codex settings (for relay/proxy, not local execution) ---
export CODEX_SANDBOX="${CODEX_SANDBOX:-danger-full-access}"
export CODEX_APPROVAL="${CODEX_APPROVAL:-never}"
export CODEX_APPROVAL_POLICY="${CODEX_APPROVAL_POLICY:-${CODEX_APPROVAL}}"

# --- Blackboard / HUD defaults ---
export FUTON3C_EXTERNAL_HUD="${FUTON3C_EXTERNAL_HUD:-1}"
export FUTON3C_DISPLAY_AGENTS_WINDOW="${FUTON3C_DISPLAY_AGENTS_WINDOW:-0}"

# --- futon1b switchover + I-0 unification (lucy live 2026-07-11; unified 2026-07-14) ---
# The stack runs futon1a-less: evidence and substrate HTTP both go to the
# futon1b XTDB2 store on :7074. As of the I-0 unification that store runs
# IN-PROCESS inside this futon3c JVM (FUTON1B_EMBED=1) instead of the separate
# futon1b-server systemd unit — one serving JVM (I-0). 127.0.0.1 is load-bearing
# (the store binds IPv4-only; localhost can resolve to ::1).
# Rollback to the two-JVM setup: FUTON1B_EMBED=0 here, then
#   systemctl --user start futon1b-server   (unit installed but disabled)
export FUTON1A_PORT="${FUTON1A_PORT:-0}"
export FUTON3C_EVIDENCE_BACKEND="${FUTON3C_EVIDENCE_BACKEND:-futon1b}"
export FUTON1B_URL="${FUTON1B_URL:-http://127.0.0.1:7074}"
export FUTON1A_URL="${FUTON1A_URL:-http://127.0.0.1:7074}"
# I-0 unification: host the futon1b XTDB2 node + HTTP inside this JVM.
# XTDB2 stores are single-process — the futon1b-server unit must stay stopped.
# (chicago uses chicago-store; see dev-linode2-env when unifying there.)
export FUTON1B_EMBED="${FUTON1B_EMBED:-1}"
export FUTON1B_STORE_DIR="${FUTON1B_STORE_DIR:-${HOME}/code/futon1b/switchover-store}"

# This check is EMBED-AWARE on purpose. Under FUTON1B_EMBED=1 the store lives
# in the futon3c JVM, so a running futon1b-server unit is the FAULT, not the
# fix: XTDB2 stores are single-process and the unit's :7074 listener makes this
# JVM's bind fail. The pre-I-0 version of this check was unconditional, so it
# alarmed on the CORRECT state and told the operator to start the unit — advice
# that causes the very "Address already in use" it was meant to prevent
# (2026-07-16). Keep the two arms in sync with FUTON1B_EMBED above.
if [[ "${FUTON1B_EMBED}" != "0" ]]; then
  if systemctl --user is-active futon1b-server.service >/dev/null 2>&1; then
    echo -e "[dev] \033[1;31m██ futon1b-server unit is RUNNING but FUTON1B_EMBED=${FUTON1B_EMBED} — it holds the :7074 store this JVM is about to embed ██\033[0m"
    echo -e "[dev] \033[31m   stop it with: systemctl --user stop futon1b-server   (or boot two-JVM: FUTON1B_EMBED=0 make dev)\033[0m"
  else
    echo "[dev] futon1b-server unit: stopped (correct — the :7074 store embeds in this JVM, I-0)"
  fi
else
  # Rollback path: FUTON1B_EMBED=0 means the separate unit serves :7074.
  if systemctl --user is-active futon1b-server.service >/dev/null 2>&1; then
    echo "[dev] futon1b-server: running (FUTON1B_EMBED=0, two-JVM rollback)"
  else
    echo -e "[dev] \033[1;31m██ futon1b-server: DOWN and FUTON1B_EMBED=0 — the I-evidence-per-turn boot check will fail ██\033[0m"
    echo -e "[dev] \033[31m   start with: systemctl --user start futon1b-server   (or embed it: FUTON1B_EMBED=1 make dev)\033[0m"
  fi
fi

# --- Futon1a/Futon4 compatibility (static dir unused while futon1a disabled) ---
export FUTON1A_STATIC_DIR="${FUTON1A_STATIC_DIR:-${HOME}/code/futon4/dev/web}"
export FUTON1A_COMPAT_PENHOLDER="${FUTON1A_COMPAT_PENHOLDER:-api}"
if [[ -z "${FUTON1A_ALLOWED_PENHOLDERS:-}" ]]; then
  export FUTON1A_ALLOWED_PENHOLDERS="${FUTON1A_COMPAT_PENHOLDER}"
elif [[ ",${FUTON1A_ALLOWED_PENHOLDERS}," != *",${FUTON1A_COMPAT_PENHOLDER},"* ]]; then
  export FUTON1A_ALLOWED_PENHOLDERS="${FUTON1A_ALLOWED_PENHOLDERS},${FUTON1A_COMPAT_PENHOLDER}"
fi
export FUTON4_BASE_URL="${FUTON4_BASE_URL:-${FUTON1A_URL}/api/alpha}"
export FUTON4_PENHOLDER="${FUTON4_PENHOLDER:-${FUTON1A_COMPAT_PENHOLDER}}"
export FUTON4_ENABLE_SYNC="${FUTON4_ENABLE_SYNC:-1}"

# --- Federation ---
# Roster completeness (M-federated-agency-hardening, 2026-07-12): lucy peers
# with Chicago by default (plus the laptop when FUTON3C_LAPTOP_URL is set)
# and runs the continuous liveness-aware sync daemon, so every box's
# *agents* roster shows all agents across all federation points. peer-sites
# arms the AG-2 guard: chi-/oxf- qualified ids are remote-homed here and
# cannot be minted as local phantoms.
if [[ -z "${FUTON3C_PEERS:-}" ]]; then
  # site=url form feeds the url→site home-site fallback for bare-id proxies.
  # oxf rides the laptop's autossh reverse tunnel (-R 17070:localhost:7070);
  # when the tunnel is down the sync daemon marks the peer stale and backs
  # off — honest absence, no boot failure.
  FUTON3C_PEERS="chi=http://172.236.108.82:7070,oxf=${FUTON3C_LAPTOP_URL:-http://127.0.0.1:17070}"
fi
export FUTON3C_PEERS
export FUTON3C_PEER_SITES="${FUTON3C_PEER_SITES:-chi,oxf}"
export FUTON3C_FED_SYNC_INTERVAL_MS="${FUTON3C_FED_SYNC_INTERVAL_MS:-30000}"

# WS federation uplink hub token (CP-F, default OFF).
# Load the untracked shared token before the final exec so the JVM can validate
# NAT'd clients using FUTON3C_FED_UPLINK.
if [[ -f "${script_dir}/../.fedtoken" ]]; then
  export FUTON3C_FED_TOKEN="${FUTON3C_FED_TOKEN:-$(<"${script_dir}/../.fedtoken")}"
fi

# --- Emacs daemon socket auto-detection (for blackboard) ---
if [[ -z "${FUTON3C_EMACS_SOCKET:-}" ]]; then
  export FUTON3C_EMACS_SOCKET="$(futon_preferred_emacs_socket || true)"
  if [[ -n "${FUTON3C_EMACS_SOCKET:-}" ]]; then
    echo "[dev] Emacs socket: ${FUTON3C_EMACS_SOCKET}"
  fi
fi

# --- IRC infrastructure health check ---
if systemctl is-active ngircd.service >/dev/null 2>&1; then
  echo "[dev] ngircd: running"
else
  echo -e "[dev] \033[1;31m██ ngircd: DOWN ██\033[0m"
  echo -e "[dev] \033[31m   restart with: sudo systemctl restart ngircd\033[0m"
fi

# Check all bridge instances (template units: ngircd-bridge@channel.service)
_any_bridge=false
for _envfile in /home/joe/.config/futon3c/bridge-*.env; do
  [[ -f "$_envfile" ]] || continue
  _chan=$(basename "$_envfile" .env)
  _chan=${_chan#bridge-}
  if systemctl --user is-active "ngircd-bridge@${_chan}.service" >/dev/null 2>&1; then
    echo "[dev] ngircd bridge #${_chan}: running"
    _any_bridge=true
  else
    echo -e "[dev] \033[1;31m██ ngircd bridge #${_chan}: DOWN ██\033[0m"
    echo -e "[dev] \033[31m   restart with: systemctl --user restart ngircd-bridge@${_chan}\033[0m"
  fi
done
if [[ "$_any_bridge" != "true" ]]; then
  # Also check legacy single service and orphan processes
  if systemctl --user is-active ngircd-bridge.service >/dev/null 2>&1; then
    echo -e "[dev] \033[33mngircd bridge: running (legacy unit — migrate to template)\033[0m"
  elif pgrep -f ngircd_bridge.py >/dev/null 2>&1; then
    echo -e "[dev] \033[33mngircd bridge: running outside systemd (orphan?)\033[0m"
  else
    echo -e "[dev] \033[1;31m██ ngircd bridge: no bridges running ██\033[0m"
  fi
fi

# --- Tickle / FM conductor CLI flags ---
# Neither starts by default. Use flags to opt in.
#   --start-tickle   Start a fresh tickle watchdog at boot
#   --resume-tickle  Resume tickle from persisted state (NYI — same as start for now)
#   --start-fm       Start the FM conductor at boot
#   --start-all      Start both tickle and FM conductor
remaining_args=()
for arg in "$@"; do
  case "$arg" in
    --start-tickle|--resume-tickle)
      export FUTON3C_TICKLE_AUTOSTART=true
      echo "[dev] Tickle watchdog: will start at boot"
      ;;
    --start-fm)
      export FUTON3C_FM_CONDUCTOR_AUTOSTART=true
      echo "[dev] FM conductor: will start at boot"
      ;;
    --start-all)
      export FUTON3C_TICKLE_AUTOSTART=true
      export FUTON3C_FM_CONDUCTOR_AUTOSTART=true
      echo "[dev] Tickle + FM conductor: will start at boot"
      ;;
    *)
      remaining_args+=("$arg")
      ;;
  esac
done

exec make dev "${remaining_args[@]+"${remaining_args[@]}"}"
