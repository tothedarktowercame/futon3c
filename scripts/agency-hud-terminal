#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/home/joe/code/futon3c/scripts/emacs-socket-lib.sh
source "${script_dir}/emacs-socket-lib.sh"
socket="${1:-${FUTON3C_HUD_SOCKET:-${FUTON3C_EMACS_SOCKET:-$(futon_preferred_emacs_socket || true)}}}"
frame_params="((name . \"Agency HUD\") (futon3c-hud . t))"
client=(emacsclient)

if [[ -n "${socket}" ]]; then
  client+=(-s "${socket}")
fi

client+=(-t -F "${frame_params}")

find_existing_hud() {
  command -v swaymsg >/dev/null 2>&1 || return 1
  command -v python3 >/dev/null 2>&1 || return 1

  python3 - <<'PY'
import json
import subprocess
import sys

def value(node, *path):
    cur = node
    for key in path:
        if not isinstance(cur, dict):
            return None
        cur = cur.get(key)
    return cur

def walk(node):
    if not isinstance(node, dict):
        return None
    app_id = value(node, "app_id")
    win_class = value(node, "window_properties", "class")
    if app_id == "agency-hud" or win_class == "agency-hud":
        con_id = value(node, "id")
        if con_id is not None:
            return con_id
    for key in ("nodes", "floating_nodes"):
        for child in node.get(key, []):
            found = walk(child)
            if found is not None:
                return found
    return None

try:
    tree = subprocess.check_output(["swaymsg", "-t", "get_tree", "-r"], text=True)
except Exception:
    sys.exit(1)

con_id = walk(json.loads(tree))
if con_id is None:
    sys.exit(1)
print(con_id)
PY
}

focus_existing_hud() {
  local con_id="$1"
  swaymsg "[con_id=${con_id}]" scratchpad show >/dev/null 2>&1 || true
  swaymsg "[con_id=${con_id}]" focus >/dev/null 2>&1 || true
}

launch_terminal() {
  local terminal="${FUTON3C_HUD_TERMINAL:-}"
  local -a candidates=()

  footclient_ready() {
    [[ -S "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/foot-wayland-1.sock" ]] \
      || [[ -S "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/foot.sock" ]] \
      || [[ -S "/tmp/foot.sock" ]]
  }

  if [[ -n "${terminal}" ]]; then
    candidates=("${terminal}")
  else
    candidates=(alacritty kitty wezterm footclient xterm)
  fi

  for candidate in "${candidates[@]}"; do
    case "${candidate}" in
      footclient)
        if command -v footclient >/dev/null 2>&1 && footclient_ready; then
          footclient --app-id agency-hud "${client[@]}" >/dev/null 2>&1 &
          disown || true
          return 0
        fi
        ;;
      alacritty)
        if command -v alacritty >/dev/null 2>&1; then
          alacritty --class agency-hud,AgencyHud -e "${client[@]}" >/dev/null 2>&1 &
          disown || true
          return 0
        fi
        ;;
      kitty)
        if command -v kitty >/dev/null 2>&1; then
          kitty --class agency-hud "${client[@]}" >/dev/null 2>&1 &
          disown || true
          return 0
        fi
        ;;
      wezterm)
        if command -v wezterm >/dev/null 2>&1; then
          wezterm start --class agency-hud -- "${client[@]}" >/dev/null 2>&1 &
          disown || true
          return 0
        fi
        ;;
      xterm)
        if command -v xterm >/dev/null 2>&1; then
          xterm -class agency-hud -e "${client[@]}" >/dev/null 2>&1 &
          disown || true
          return 0
        fi
        ;;
    esac
  done

  echo "agency-hud-terminal: no supported terminal emulator found" >&2
  exit 1
}

if con_id="$(find_existing_hud 2>/dev/null)"; then
  focus_existing_hud "${con_id}"
  exit 0
fi

launch_terminal
