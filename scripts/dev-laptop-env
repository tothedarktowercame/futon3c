#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/home/joe/code/futon3c/scripts/emacs-socket-lib.sh
source "${script_dir}/emacs-socket-lib.sh"

# Laptop profile for futon3c dev.
# Just run: ./scripts/dev-laptop-env
#
# All role-specific knowledge is baked in. Override env vars only if
# you know what you're doing.

# --- Role & network ---
# Force the role (not ${FUTON3C_ROLE:-laptop}): this launcher's whole job is the
# laptop profile, and the `:-` default silently deferred to a stale FUTON3C_ROLE
# inherited in the shell (e.g. left by a prior dev-linode-env), which made codex-1
# register as a remote laptop-slot and wedge after restart. Forcing it kills that.
export FUTON3C_ROLE="laptop"
# Durable per-agent turn queue (Car-3): accept->enqueue->drain replaces
# lock-then-invoke for same-agent turns (ordered drain, no-drop, per-surface
# reply routing, msg-id dedup). Activated 2026-06-10. Set "false" to revert to
# the legacy lock path.
export FUTON3C_DURABLE_QUEUE="${FUTON3C_DURABLE_QUEUE:-true}"
# Kangaroo warm pouch (M-kangaroo): one persistent `claude --input-format
# stream-json` process per agent instead of cold `claude -p --resume` per turn.
# Takes effect for agents minted after start (cr new); existing agents stay cold
# until re-minted. Set "false" to revert. Activated 2026-06-10.
export FUTON3C_KANGAROO="${FUTON3C_KANGAROO:-true}"
# Joey gate: a pouch warms only a SMALL session ("joey"). A "monster" (transcript
# over FUTON3C_KANGAROO_JOEY_MAX_BYTES, default 2 MiB) stays COLD — warming a giant
# history is a token-cost trap (the server-side prompt cache re-prefills it past its
# 5-min TTL regardless of process warmth). Override per-agent at the REPL with
# (futon3c.agency.agent-pouch/allow-monster! "<id>"), or globally:
export FUTON3C_KANGAROO_JOEY_MAX_BYTES="${FUTON3C_KANGAROO_JOEY_MAX_BYTES:-2097152}"
# export FUTON3C_KANGAROO_ALLOW_MONSTERS=true   # warm every session regardless of size
# Durable per-agent monster overrides (E5: warming an ACTIVELY-USED monster WINS —
# amortize the transcript read once at spawn instead of every cold turn; on the Max
# subscription the token-trap rationale doesn't apply within included usage). The
# in-memory allow-monster! list dies with the JVM; this one survives restart.
export FUTON3C_KANGAROO_MONSTER_ALLOWLIST="${FUTON3C_KANGAROO_MONSTER_ALLOWLIST:-claude-3,fable-1}"
# Drainer v2 (M-agency-hardening drainer car): a dedicated per-agent drainer thread
# owns drain+finalization so a bell enqueues and returns instead of parking one of the
# 4 shared invoke-executor lanes on @waiter (the lane-burn that backs the queue up).
# Validated by futon3c.agency.drainer-model-test. Activated 2026-06-10. Set "false"
# to revert to the legacy invoke path (byte-for-byte). Takes effect on restart.
export FUTON3C_DRAINER_V2="${FUTON3C_DRAINER_V2:-true}"
# Desktop Save Mode (M-agency-hardening W5): the registry roster is persisted to
# disk continuously (always-on); this flag turns on RESTORE-on-boot, so a JVM
# shutdown+restart brings the same agents back registered — and warm, since
# restore rebuilds invoke-fns via the kangaroo-gated factory. Activated
# 2026-06-10. Roster path override: FUTON3C_AGENT_ROSTER_FILE.
# Typed bells (M-typed-bells): a bell may declare an IAT illocutionary type
# (type=query/answer/...) + an optional ref; query/answer populate ArSE at send-time.
# Default OFF preserves the legacy bell path byte-for-byte; turning ON activates the
# live ArSE-population monitoring. Reviewed (author≠reviewer) on commit b4ed15f;
# logic model TB-1..7 PASS. Activated 2026-06-11 for live ArSE-usage monitoring. Set
# "false" to revert. Watch-item once live: holes/tickets/T-typed-bell-arse-write-async.md.
export FUTON3C_TYPED_BELLS="${FUTON3C_TYPED_BELLS:-true}"
# Parked-on continuations (README-park.md, E-repl-continuations): agents park a
# REPL turn on dispatched agency job-ids and are resumed in-buffer when the join
# completes — the only reliable cross-turn wait on the emacs-repl surface (harness
# background tasks don't survive pouch teardown). Engine is unit-tested (5 VERIFY
# cases); flag-gated OFF upstream, defaulted ON here 2026-07-05 (Joe, via
# claude-18 session). Boot runs rehydrate! + the 30s deadline sweeper. Set
# "false" to revert.
export FUTON3C_PARKED_ON="${FUTON3C_PARKED_ON:-true}"
# Invoke-executor lanes: shared pool for agent invocations. Bumped 4 -> 8
# (2026-06-12) now that drainer-v2 keeps bell turns off these lanes, so a Codex
# swarm can run in parallel to Claude WIP. Takes effect on JVM restart.
export FUTON3C_INVOKE_LANES="${FUTON3C_INVOKE_LANES:-8}"
# E2 (turn-delivery-invariants.md): route /invoke-stream (REPL/operator turns) through the
# durable turn-queue + per-agent drainer, so an operator turn gets the SAME guarantees as a
# bell — single-writer (no shared-lane race), durable, reply routed to its own SSE channel.
# Default OFF preserves the legacy direct-invoke path byte-for-byte; requires drainer-v2.
# Verified live 2026-06-12 (single-writer + own-reply + no cross-talk; OFF regression clean).
# Activated 2026-06-12 per Joe ("REPL turns shouldn't get lost"). Set "false" to revert.
export FUTON3C_REPL_THROUGH_QUEUE="${FUTON3C_REPL_THROUGH_QUEUE:-true}"
export FUTON3C_AGENT_RESTORE="${FUTON3C_AGENT_RESTORE:-true}"
export FUTON3C_BIND_HOST="${FUTON3C_BIND_HOST:-127.0.0.1}"
export FUTON3C_PORT="${FUTON3C_PORT:-7070}"
export FUTON3C_LINODE_URL="${FUTON3C_LINODE_URL:-http://172.236.28.208:7070}"
export FUTON3C_AGENCY_BASE="${FUTON3C_AGENCY_BASE:-http://127.0.0.1:${FUTON3C_PORT}}"
export FUTON3C_EVIDENCE_BASE="${FUTON3C_EVIDENCE_BASE:-${FUTON3C_LINODE_URL}}"

# --- IRC: disabled on laptop (ngircd runs on Linode) ---
export FUTON3C_IRC_PORT="${FUTON3C_IRC_PORT:-0}"

# --- Agents: Codex runs here, Claude runs on Linode ---
export FUTON3C_REGISTER_CODEX="${FUTON3C_REGISTER_CODEX:-true}"
export FUTON3C_REGISTER_CLAUDE="${FUTON3C_REGISTER_CLAUDE:-false}"
export FUTON3C_TICKLE_AUTOSTART="${FUTON3C_TICKLE_AUTOSTART:-false}"
export FUTON3C_FM_CONDUCTOR_AUTOSTART="${FUTON3C_FM_CONDUCTOR_AUTOSTART:-false}"

# --- Codex settings ---
export CODEX_SANDBOX="${CODEX_SANDBOX:-danger-full-access}"
export CODEX_APPROVAL="${CODEX_APPROVAL:-never}"
export CODEX_APPROVAL_POLICY="${CODEX_APPROVAL_POLICY:-${CODEX_APPROVAL}}"

# Run codex-1 INLINE (direct local invoke-fn, route :local) instead of via a WS
# bridge. By default (role=laptop) codex registers through a WS bridge to the
# Linode hub (FUTON3C_LINODE_URL), so the laptop-resident codex worker depended
# on a remote box: every hub restart zombied the bridge and codex-1 silently
# dropped work. The worker is local and its work originates locally, so the
# bridge buys nothing here (evidence replication is off for a local target
# anyway) and only adds a failure mode. Disabling it registers codex-1 with a
# direct local invoke-fn — no bridge to zombie, no remote dependency. This is
# the configuration verified working 2026-06-16 (whistle round-trip). The
# liveness-ping fix in dev.clj still hardens the bridge path for boxes that DO
# use it. Trade-off: Linode-side agents can't reach codex-1 directly — that
# needs the federation-proxy work in M-federated-agency-hardening.
export FUTON3C_CODEX_WS_BRIDGE="${FUTON3C_CODEX_WS_BRIDGE:-false}"

# --- Blackboard / HUD defaults ---
export FUTON3C_EXTERNAL_HUD="${FUTON3C_EXTERNAL_HUD:-1}"
export FUTON3C_DISPLAY_AGENTS_WINDOW="${FUTON3C_DISPLAY_AGENTS_WINDOW:-0}"
export FUTON3C_HUD_TERMINAL="${FUTON3C_HUD_TERMINAL:-alacritty}"

# --- futon1b switchover (E-futon1b-operational-switchover; laptop live 2026-07-12) ---
# The stack runs futon1a-less: evidence and substrate HTTP both go to the
# futon1b store JVM (systemd user unit futon1b-server.service, migration-store-21,
# :7073 — the FULL corpus, data-first path; NOT the lucy :7074 switchover-store).
# 127.0.0.1 is load-bearing (the store JVM binds IPv4-only; localhost can resolve
# to ::1). Rollback: FUTON1A_PORT=7071 + unset the three below (boots futon1a).
export FUTON1A_PORT="${FUTON1A_PORT:-0}"
export FUTON3C_EVIDENCE_BACKEND="${FUTON3C_EVIDENCE_BACKEND:-futon1b}"
export FUTON1B_URL="${FUTON1B_URL:-http://127.0.0.1:7073}"
export FUTON1A_URL="${FUTON1A_URL:-http://127.0.0.1:7073}"

if systemctl --user is-active futon1b-server.service >/dev/null 2>&1; then
  echo "[dev] futon1b-server: running (:7073, migration-store-21)"
else
  echo -e "[dev] \033[1;31m██ futon1b-server: DOWN — the I-evidence-per-turn boot check will fail ██\033[0m"
  echo -e "[dev] \033[31m   start with: systemctl --user start futon1b-server\033[0m"
fi

# --- Futon1a/Futon4 compatibility (static dir unused while futon1a disabled) ---
export FUTON1A_COMPAT_PENHOLDER="${FUTON1A_COMPAT_PENHOLDER:-api}"
if [[ -z "${FUTON1A_ALLOWED_PENHOLDERS:-}" ]]; then
  export FUTON1A_ALLOWED_PENHOLDERS="${FUTON1A_COMPAT_PENHOLDER}"
elif [[ ",${FUTON1A_ALLOWED_PENHOLDERS}," != *",${FUTON1A_COMPAT_PENHOLDER},"* ]]; then
  export FUTON1A_ALLOWED_PENHOLDERS="${FUTON1A_ALLOWED_PENHOLDERS},${FUTON1A_COMPAT_PENHOLDER}"
fi
export FUTON4_BASE_URL="${FUTON4_BASE_URL:-${FUTON1A_URL}/api/alpha}"
export FUTON4_PENHOLDER="${FUTON4_PENHOLDER:-${FUTON1A_COMPAT_PENHOLDER}}"
export FUTON4_ENABLE_SYNC="${FUTON4_ENABLE_SYNC:-1}"
export FUTON3C_MULTI_WATCHER_AUTOSTART="${FUTON3C_MULTI_WATCHER_AUTOSTART:-false}"
export FUTON3C_MULTI_WATCHER_INTERVAL_MS="${FUTON3C_MULTI_WATCHER_INTERVAL_MS:-5000}"
export FUTON3C_MULTI_WATCHER_DEBOUNCE_MS="${FUTON3C_MULTI_WATCHER_DEBOUNCE_MS:-250}"
export FUTON3C_MULTI_WATCHER_PIDFILE="${FUTON3C_MULTI_WATCHER_PIDFILE:-/tmp/multi-watcher.pid}"
export FUTON3C_MULTI_WATCHER_LOGFILE="${FUTON3C_MULTI_WATCHER_LOGFILE:-/tmp/multi-watcher.log}"

# --- Web UIs: start CLJS/web sidecars alongside the JVM ---
export FUTON3C_WAR_MACHINE_AUTOSTART="${FUTON3C_WAR_MACHINE_AUTOSTART:-true}"
export FUTON3C_WAR_MACHINE_PIDFILE="${FUTON3C_WAR_MACHINE_PIDFILE:-/tmp/war-machine-web.pid}"
export FUTON3C_WAR_MACHINE_LOGFILE="${FUTON3C_WAR_MACHINE_LOGFILE:-/tmp/war-machine-web.log}"
export FUTON3C_WEBARXANA_AUTOSTART="${FUTON3C_WEBARXANA_AUTOSTART:-true}"
export FUTON3C_WEBARXANA_PIDFILE="${FUTON3C_WEBARXANA_PIDFILE:-/tmp/webarxana-web.pid}"
export FUTON3C_WEBARXANA_LOGFILE="${FUTON3C_WEBARXANA_LOGFILE:-/tmp/webarxana-web.log}"
# Laptop = DEV all the time: skip the WebArxana session gate so Playwright / curl
# can drive /wa without logging in. Read by webarxana.server.auth/dev-no-auth?.
export WEBARXANA_DEV_NO_AUTH="${WEBARXANA_DEV_NO_AUTH:-1}"

# --- Federation: peer with Linode unless explicitly disabled ---
if [[ "${FUTON3C_DISABLE_AUTO_PEERS:-false}" != "true" && -z "${FUTON3C_PEERS:-}" ]]; then
  export FUTON3C_PEERS="${FUTON3C_LINODE_URL}"
fi

# Roster-completeness (M-federated-agency-hardening): arm the continuous sync
# daemon so the laptop continuously pulls the peer's roster instead of relying
# on the one-shot sync-peers! at boot. Without this, agents that appear on the
# peer AFTER the laptop boots (e.g. claude-6 on London) never propagate — the
# laptop's roster is frozen at boot time. Default 60000 ms (1 min); set 0 to
# revert to boot-only sync. Peer fetch failures skip that tick rather than
# pruning proxies (AG-3/AG-4 liveness model from CP-B slice 2).
export FUTON3C_FED_SYNC_INTERVAL_MS="${FUTON3C_FED_SYNC_INTERVAL_MS:-60000}"
# Cap retry backoff when a peer is unreachable (default 5 min).
export FUTON3C_FED_SYNC_MAX_BACKOFF_MS="${FUTON3C_FED_SYNC_MAX_BACKOFF_MS:-300000}"

# Peer sites (CP-B slice 1 AG-2 guard): lon-* and chi-* ids are remote-homed.
# Setting this arms the registration-seam refusal guard so the emacs repl-attach
# path cannot mint local phantoms for agents that belong on London or Chicago
# (the root cause of the original lon-claude-1 / chi-claude-1 phantom bug).
export FUTON3C_PEER_SITES="${FUTON3C_PEER_SITES:-lon,chi}"

# FUTON3C_SITE: intentionally unset on the laptop for now. Setting it to "oxf"
# would rename all locally-registered agents (claude-1 → oxf-claude-1, etc.) —
# the universal site-qualification direction that CP-C deferred as needing
# claude-repl.el cooperation and coordinated agent renames. The laptop is the
# last box without a site code; adopting "oxf" is the prerequisite for full
# universal site-qualification across the federation.

# FUTON3C_SELF_URL: intentionally unset on the laptop. The laptop binds to
# 127.0.0.1 (not reachable from remote boxes), so announce! cannot hand London
# a valid origin-url — the laptop→London announce direction requires a
# network-level path (tunnel or public bind). Until then, London learns about
# laptop agents only if London peers with the laptop (FUTON3C_LAPTOP_URL on
# London's side). The London→laptop direction works fine via sync-pull because
# the laptop initiates the outbound connection.

# --- Emacs daemon socket auto-detection (for blackboard) ---
if [[ -z "${FUTON3C_EMACS_SOCKET:-}" ]]; then
  export FUTON3C_EMACS_SOCKET="$(futon_preferred_emacs_socket || true)"
  if [[ -n "${FUTON3C_EMACS_SOCKET:-}" ]]; then
    echo "[dev] Emacs socket: ${FUTON3C_EMACS_SOCKET}"
  fi
fi

# --- Tickle / FM conductor CLI flags ---
remaining_args=()
for arg in "$@"; do
  case "$arg" in
    --start-tickle|--resume-tickle)
      export FUTON3C_TICKLE_AUTOSTART=true
      echo "[dev] Tickle watchdog: will start at boot"
      ;;
    --start-fm)
      export FUTON3C_FM_CONDUCTOR_AUTOSTART=true
      echo "[dev] FM conductor: will start at boot"
      ;;
    --start-all)
      export FUTON3C_TICKLE_AUTOSTART=true
      export FUTON3C_FM_CONDUCTOR_AUTOSTART=true
      echo "[dev] Tickle + FM conductor: will start at boot"
      ;;
    --fresh)
      # Clean boot: skip restore-on-boot so the JVM comes up with NO restored
      # agents (mint new ones via cr/cx) and fresh invoke lanes/drainers.
      # CRITICAL: also SUSPEND persistence (FUTON3C_ROSTER_PERSIST=false).  Without
      # this, "persistence always on" overwrote the durable snapshot with the empty
      # --fresh registry, so a later non-fresh boot had nothing to restore — the
      # roster-loss bug of 2026-06-13.  With persistence suspended, --fresh is truly
      # non-destructive: the snapshot is preserved and a later non-fresh boot restores it.
      export FUTON3C_AGENT_RESTORE=false
      export FUTON3C_ROSTER_PERSIST=false
      echo "[dev] --fresh: restore-on-boot OFF + persistence SUSPENDED — clean slate, durable roster snapshot preserved"
      ;;
    *)
      remaining_args+=("$arg")
      ;;
  esac
done

local_override="${BASH_SOURCE[0]}.local"
if [[ -f "$local_override" ]]; then
  # shellcheck source=/dev/null
  source "$local_override"
  echo "[dev] Loaded local overrides: $(basename "$local_override")"
fi

futon1a_data_dir() {
  printf '%s\n' "${FUTON1A_DATA_DIR:-${HOME}/code/storage/futon1a/default}"
}

port_listening() {
  local port="$1"
  ss -ltn 2>/dev/null | awk '{print $4}' | grep -Eq "(^|:)${port}$"
}

port_listener_pid() {
  local port="$1"
  ss -ltnp 2>/dev/null \
    | awk -v port=":${port}" '$4 ~ port {print $NF}' \
    | sed -n 's/.*pid=\([0-9][0-9]*\).*/\1/p' \
    | head -n 1
}

show_futon1a_lock_conflict_and_exit() {
  local lockfile="$1"
  local pid="$2"
  local proc_name active_ports=()
  proc_name="$(ps -p "$pid" -o comm= 2>/dev/null || true)"
  for port in "${FUTON3C_PORT:-7070}" "${FUTON1A_PORT:-7071}" "${FUTON5_PORT:-7072}" "${FUTON3C_DRAWBRIDGE_PORT:-6768}"; do
    if port_listening "$port"; then
      active_ports+=("$port")
    fi
  done

  echo "[dev] futon1a data dir is already locked by pid ${pid}"
  echo "      lock: ${lockfile}"
  if [[ -n "$proc_name" ]]; then
    echo "      process: ${proc_name}"
  fi
  if [[ ${#active_ports[@]} -gt 0 ]]; then
    echo "      active dev ports: ${active_ports[*]}"
  fi
  echo "[dev] Another dev JVM is probably already running."
  echo "      Reuse that session, stop pid ${pid}, or point FUTON1A_DATA_DIR/FUTON1A_PORT elsewhere."
  exit 1
}

preflight_futon1a_lock() {
  local data_dir lockfile pid
  data_dir="$(futon1a_data_dir)"
  lockfile="${data_dir}/index-store/LOCK"
  [[ -e "$lockfile" ]] || return 0

  pid=""
  if command -v lsof >/dev/null 2>&1; then
    pid="$(lsof -t -- "$lockfile" 2>/dev/null | head -n 1 || true)"
  fi
  if [[ -z "$pid" ]] && command -v fuser >/dev/null 2>&1; then
    pid="$(fuser "$lockfile" 2>/dev/null | awk '{print $1}' || true)"
  fi
  [[ -n "$pid" ]] || return 0

  show_futon1a_lock_conflict_and_exit "$lockfile" "$pid"
}

watcher_pid_running() {
  local pidfile="$1"
  [[ -f "$pidfile" ]] || return 1
  local pid
  pid="$(cat "$pidfile" 2>/dev/null || true)"
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

find_shadow_watch_pid() {
  local project_dir="$1"
  ps -ww -eo pid=,cmd= \
    | grep -F "${project_dir}/node_modules/.bin/shadow-cljs watch app" \
    | grep -v grep \
    | awk '{print $1}' \
    | tail -n 1
}

ensure_nvm_snippet() {
  cat <<'EOF'
if [[ -n "${NVM_DIR:-}" && -s "${NVM_DIR}/nvm.sh" ]]; then
  # shellcheck source=/dev/null
  . "${NVM_DIR}/nvm.sh"
elif [[ -s "${HOME}/.nvm/nvm.sh" ]]; then
  export NVM_DIR="${HOME}/.nvm"
  # shellcheck source=/dev/null
  . "${NVM_DIR}/nvm.sh"
fi
EOF
}

terminate_pid_if_running() {
  local pid="$1"
  [[ -n "$pid" ]] || return 0
  kill "$pid" 2>/dev/null || true
}

start_shadow_watch_sidecar() {
  local name="$1"
  local project_dir="$2"
  local pidfile="$3"
  local logfile="$4"
  local url="${5:-}"
  local health_port="${6:-}"
  local actual_pid
  local nvm_snippet
  local -i wait_step_seconds=2
  local -i wait_steps=6
  local -i step=0

  nvm_snippet="$(ensure_nvm_snippet)"

  if watcher_pid_running "$pidfile"; then
    if [[ -n "$health_port" ]] && ! port_listening "$health_port"; then
      echo "[dev] ${name} pid $(cat "$pidfile") is up but port ${health_port} is not; restarting"
      terminate_pid_if_running "$(cat "$pidfile")"
      rm -f "$pidfile"
    else
      echo "[dev] ${name} already running (pid $(cat "$pidfile"))${url:+ at ${url}}"
      return 0
    fi
  fi

  if [[ -n "$health_port" ]] && port_listening "$health_port"; then
    actual_pid="$(port_listener_pid "$health_port" || true)"
    if [[ -n "$actual_pid" ]]; then
      echo "$actual_pid" > "$pidfile"
      echo "[dev] ${name} already online (pid ${actual_pid})${url:+ at ${url}}"
      return 0
    fi
  fi

  actual_pid="$(find_shadow_watch_pid "$project_dir" || true)"
  if [[ -n "$actual_pid" ]]; then
    if [[ -n "$health_port" ]] && ! port_listening "$health_port"; then
      echo "[dev] ${name} process ${actual_pid} exists but port ${health_port} is not live; restarting"
      terminate_pid_if_running "$actual_pid"
      actual_pid=""
    else
      echo "$actual_pid" > "$pidfile"
      echo "[dev] ${name} already running (pid ${actual_pid})${url:+ at ${url}}"
      return 0
    fi
  fi

  rm -f "$pidfile"
  echo "[dev] Starting ${name}${url:+ at ${url}}"
  setsid bash -lc "
    ${nvm_snippet}
    cd '${project_dir}'
    exec npm run dev </dev/null >>'${logfile}' 2>&1
  " &
  echo $! > "$pidfile"
  sleep 2

  if ! watcher_pid_running "$pidfile"; then
    actual_pid="$(find_shadow_watch_pid "$project_dir" || true)"
    if [[ -n "$actual_pid" ]]; then
      echo "$actual_pid" > "$pidfile"
    fi
  fi

  if ! watcher_pid_running "$pidfile"; then
    echo "[dev] ${name} failed to stay up; see ${logfile}" >&2
    return 1
  fi

  if [[ -n "$health_port" ]]; then
    while (( step < wait_steps )); do
      if port_listening "$health_port"; then
        break
      fi
      sleep "$wait_step_seconds"
      ((step+=1))
    done
    if ! port_listening "$health_port"; then
      echo "[dev] ${name} started but port ${health_port} is not listening; see ${logfile}" >&2
      return 1
    fi
  fi

  actual_pid="$(find_shadow_watch_pid "$project_dir" || true)"
  if [[ -n "$actual_pid" ]]; then
    echo "$actual_pid" > "$pidfile"
  elif [[ -n "$health_port" ]]; then
    actual_pid="$(port_listener_pid "$health_port" || true)"
    if [[ -n "$actual_pid" ]]; then
      echo "$actual_pid" > "$pidfile"
    fi
  fi

  echo "[dev] ${name} pid $(cat "$pidfile") log ${logfile}${url:+ url ${url}}"
}

start_web_sidecars() {
  local war_machine_dir="${HOME}/code/futon2/web/war-machine"
  local webarxana_dir="${HOME}/code/futon4/dev/web/webarxana"

  if [[ "${FUTON3C_WAR_MACHINE_AUTOSTART}" == "true" ]]; then
    start_shadow_watch_sidecar \
      "War Machine web" \
      "$war_machine_dir" \
      "${FUTON3C_WAR_MACHINE_PIDFILE}" \
      "${FUTON3C_WAR_MACHINE_LOGFILE}" \
      "http://localhost:8710" \
      "8710"
  fi

  if [[ "${FUTON3C_WEBARXANA_AUTOSTART}" == "true" ]]; then
    start_shadow_watch_sidecar \
      "WebArxana CLJS watcher" \
      "$webarxana_dir" \
      "${FUTON3C_WEBARXANA_PIDFILE}" \
      "${FUTON3C_WEBARXANA_LOGFILE}" \
      "http://localhost:9631" \
      "9631"
  fi
}

retire_old_bb_multi_watcher() {
  local old_pids
  old_pids="$(ps -ww -eo pid=,cmd= | grep 'bb /home/joe/code/futon3/scripts/multi_watcher.clj' | grep -v grep | awk '{print $1}' || true)"
  if [[ -n "$old_pids" ]]; then
    echo "[dev] Retiring old bb multi-watcher: $old_pids"
    while read -r pid; do
      [[ -n "$pid" ]] || continue
      kill "$pid" 2>/dev/null || true
    done <<< "$old_pids"
  fi
}

find_jvm_multi_watcher_pid() {
  local repo_base="$1"
  ps -ww -eo pid=,cmd= \
    | grep 'clojure.main scripts/multi_watcher_jvm.clj' \
    | grep -F "${repo_base}/futon0=futon0-d" \
    | grep -v grep \
    | awk '{print $1}' \
    | tail -n 1
}

start_multi_watcher() {
  # E-live-means-live Path B (2026-05-01): the multi-watcher now runs
  # IN-JVM as a service started by futon3c.dev.bootstrap (see
  # futon3c/src/futon3c/watcher/multi.clj + bootstrap.clj). The
  # separate-process bb watcher launched by this function has been
  # retired. Keeping the function as a no-op + orphan-cleanup so any
  # stale bb watchers from before the cutover get reaped on the next
  # `make dev`.
  retire_old_bb_multi_watcher
  rm -f "${FUTON3C_MULTI_WATCHER_PIDFILE:-/tmp/multi-watcher.pid}"
  if [[ "${FUTON3C_MULTI_WATCHER_AUTOSTART}" == "true" ]]; then
    echo "[dev] FUTON3C_MULTI_WATCHER_AUTOSTART=true is deprecated;"
    echo "      the watcher runs in-JVM via futon3c.dev.bootstrap now."
  fi
  return 0
}

start_multi_watcher_LEGACY_BB() {
  # Preserved for reference / rollback. Do not call from the env script.
  [[ "${FUTON3C_MULTI_WATCHER_AUTOSTART}" == "true" ]] || return 0

  local repo_base watcher_log watcher_pid clojure_bin actual_pid
  repo_base="${FUTON3C_REPO_BASE:-${FUTON_REPO_BASE:-${HOME}/code}}"
  watcher_log="${FUTON3C_MULTI_WATCHER_LOGFILE}"
  watcher_pid="${FUTON3C_MULTI_WATCHER_PIDFILE}"
  if [[ -x "${repo_base}/futon3/.tools/clojure/bin/clojure" ]]; then
    clojure_bin="${repo_base}/futon3/.tools/clojure/bin/clojure"
  else
    clojure_bin="clojure"
  fi

  retire_old_bb_multi_watcher

  if watcher_pid_running "$watcher_pid"; then
    echo "[dev] Multi-watcher already running (pid $(cat "$watcher_pid"))"
    return 0
  fi

  actual_pid="$(find_jvm_multi_watcher_pid "$repo_base" || true)"
  if [[ -n "$actual_pid" ]]; then
    echo "$actual_pid" > "$watcher_pid"
    echo "[dev] Multi-watcher already running (pid ${actual_pid})"
    return 0
  fi

  rm -f "$watcher_pid"
  echo "[dev] Starting JVM multi-watcher"
  nohup bash -lc "
    cd '${repo_base}/futon3'
    exec '${clojure_bin}' -M scripts/multi_watcher_jvm.clj \
      --root '${repo_base}/futon0=futon0-d' \
      --root '${repo_base}/futon1=futon1-d' \
      --root '${repo_base}/futon1a=futon1a-d' \
      --root '${repo_base}/futon2=futon2-d' \
      --root '${repo_base}/futon3=futon3-d' \
      --root '${repo_base}/futon3a=futon3a-d' \
      --root '${repo_base}/futon3b=futon3b-d' \
      --root '${repo_base}/futon3c=futon3c-d' \
      --root '${repo_base}/futon4=futon4-elisp-d' \
      --root '${repo_base}/futon5=futon5-d2' \
      --root '${repo_base}/futon5a=futon5a-d' \
      --root '${repo_base}/futon6=futon6-py-d' \
      --root '${repo_base}/futon7=futon7-d' \
      --interval-ms '${FUTON3C_MULTI_WATCHER_INTERVAL_MS}' \
      --debounce-ms '${FUTON3C_MULTI_WATCHER_DEBOUNCE_MS}' \
      --no-cold-scan
  " >>"$watcher_log" 2>&1 &
  echo $! > "$watcher_pid"
  sleep 1
  if ! watcher_pid_running "$watcher_pid"; then
    actual_pid="$(find_jvm_multi_watcher_pid "$repo_base" || true)"
    if [[ -n "$actual_pid" ]]; then
      echo "$actual_pid" > "$watcher_pid"
    fi
  fi
  if ! watcher_pid_running "$watcher_pid"; then
    echo "[dev] JVM multi-watcher failed to stay up; see ${watcher_log}" >&2
    return 1
  fi
  echo "[dev] Multi-watcher pid $(cat "$watcher_pid") log ${watcher_log}"
}

preflight_futon1a_lock
start_web_sidecars
start_multi_watcher

exec make dev "${remaining_args[@]+"${remaining_args[@]}"}"
