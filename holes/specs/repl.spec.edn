;; =============================================================================
;; The futon REPL as a differential operator over the active-inference manifold
;; =============================================================================
;;
;; A SPECIFICATION, not an anatomy: every claim below is stated so that a
;; checker over a REPL turn-trace can decide whether observed behaviour
;; conforms.  Authored 2026-05-29 by claude-2 (emacs-repl) from Joe's
;; directive: "I want the specification in .edn ... I'd like to be able to
;; verify behaviour matches the spec ... getting the mathematical formalism
;; in place is more important [than who-merges details]."
;;
;; LEVEL.  This spec sits ABOVE M-pilot-appearance (what the pilot sees),
;; above the working-class excursions (E-night-shift / E-street-sweeper /
;; E-pattern-mining), and above M-a-sorry-enterprise.  Those are instances /
;; implementations beneath this operator; the REPL contract is higher level.
;;
;; FORMALISM.  The REPL is the application-and-integration of a differential
;; operator on substrate-2's state manifold.  The War Machine IS v·∇ (a
;; derivation).  One step = LOOP ∘ PRINT ∘ EVAL ∘ READ
;;             = integrate φ ∘ deform ∇ ∘ contract dT with v ∘ disclose dT.
;;
;; POLICY DEFERRED (operator directive 2026-05-29): WHO supplies v (operator
;; vs full-auto pilot) and WHO replays which branch into master are policy
;; choices ON this operator, not part of the operator's definition.  Captured
;; in :policy below as open knobs; the formalism does not depend on them.
;; =============================================================================

{:spec/id      :futon-repl
 :spec/title   "The futon REPL as a differential operator over the AIF manifold"
 :spec/version "0.1"
 :spec/authored {:by "claude-2" :on "2026-05-29" :surface "emacs-repl"}
 :spec/level
 {:above ["M-pilot-appearance (the pilot's contract / what it sees)"
          "E-night-shift / E-street-sweeper / E-pattern-mining (implementations)"
          "M-a-sorry-enterprise (the larger LOOP-phase build)"]
  :note  "those are instances beneath this operator; this is the REPL contract itself"}

 ;; ==========================================================================
 ;; 1. OBJECTS — the differential-geometric formalism, each tied to substrate
 ;; ==========================================================================
 :objects
 {:M   {:name "state manifold"
        :points "futon-stack states: open sorries, mission phases, the typed-edge graph"
        :realised-by "substrate-2"}

  :T   {:name "potential field" :type "M → ℝ"
        :is  "Expected Free Energy G (the WM's per-action g-total). Identified with tension / negative-aliveness."
        :convention "lower (more negative) g = more pending pressure; an action's g is how strongly the field pulls toward taking it"
        :realised-by "WM :judgement; per-action :g-total (witnessed value address-sorry G=-4.99)"
        :grounding "aliveness-synthesis (T, EFE-G, aliveness are projections of one quantity); take T := G"}

  :TpM {:name "tangent space at p"
        :is  "the admissible actions at state p"
        :basis "the candidate actions enumerated in :ranked-actions at p"}

  :dT  {:name "differential / cotangent at p" :type "TpM → ℝ"
        :def "dT_p(a) = predicted change in the field from action a"
        :realised-by "the :ranked-actions list IS dT_p: each entry = (action, g-total[, delta-T]) = one component over the action-basis"
        :anchor "stack_generator.clj:396-491 (next-move projection from judgement.ranked-actions); :rank + :g-total per entry"}

  :v   {:name "chosen tangent vector (the DIRECTION)"
        :is  "the inhabitant's selected action(s) at p — the move actually committed to"
        :realised-by "a minted consent-gate-event (cg-id) naming the chosen :action"
        :grounding "reflective-discipline: 'PARs are tangent vectors; we are still just building the manifold'"}

  :D_v {:name "directional derivative — THE operator"
        :def "D_v T = dT_p(v) = predicted discharge along v"
        :is  "the War Machine proper: v·∇, a derivation. Undefined unless v is supplied — see :V2."}

  :∇   {:name "connection"
        :is  "the typed-edge inventory; it fixes which actions are admissible (the basis of TpM)"
        :deformed-when "a new typed-edge family is introduced (niche construction); dim(TpM) changes"
        :grounding "niche-construction: an agent cannot extend its own typed-edge inventory; ΔT=0 false-floor = a missing edge family, not a resolved direction"}

  :φ   {:name "flow"
        :is  "state advance + field relaxation over one step"
        :realised-by "a WM scheduler tick (~300s) recomputing :judgement; the field relaxes and the next dT is over a possibly-changed basis"}}

 ;; ==========================================================================
 ;; 2. OPERATOR — one REPL step, and the trace it must emit
 ;; ==========================================================================
 :operator
 {:def   "REPL_step(p) = LOOP ∘ PRINT ∘ EVAL ∘ READ"
  :curve "a session is the integral curve γ = [turn-record …]; skill lives in the path, not the endpoints (see :V5)"
  :turn-record
  {:turn               "#{:READ :EVAL :PRINT :LOOP}"
   :p                  "state identifier at entry"
   :dT-snapshot        "[{:action _ :g-total _ :delta-T _}|{:action _ :g-total :⊥}] — emitted by READ"
   :v                  "chosen action — emitted by EVAL (nil before EVAL)"
   :v-attribution      "#{:operator :pilot-autonomous} — who supplied v"
   :predicted-discharge "D_v T, taken from dT-snapshot at the chosen action — emitted by EVAL"
   :cg-id              "consent-gate-event id (cg-…) — emitted by EVAL, cited by PRINT"
   :artefact           "what PRINT emitted (branch ref / commit / typed edge)"
   :delta-∇?           "bool — did PRINT introduce a new typed-edge family?"
   :p'                 "state identifier after LOOP"
   :realised-discharge "measured field-change bracketing the action — emitted by LOOP"
   :prediction-error   "|realised-discharge − predicted-discharge| — emitted by LOOP"}}

 ;; ==========================================================================
 ;; 3. TURNS — pre/post-condition contracts
 ;; ==========================================================================
 :turns
 [{:turn :READ
   :geometry "dT_p : TpM → ℝ      (disclose the cotangent: slope in every direction)"
   :gloss    "anamnesis discloses"
   :requires []
   :ensures  ["emits :dT-snapshot = finite set {(aᵢ, gᵢ)} over the admissible action-basis at p"
              "every admissible action has gᵢ ∈ ℝ OR an explicit false-floor gᵢ = :⊥ — never a silent 0 (see :V1)"]
   :backing  {:status :live
              :anchor "stack_generator.clj:396-491; war_machine_pilot_shapes.clj:44-46 observe tools (:anchors-read :wm-api-query :playwright-probe-run)"}}

  {:turn :EVAL
   :geometry "D_v T = dT_p(v)      (contract dT with the inhabitant's chosen direction)"
   :gloss    "anamnesis discharges"
   :requires [":dT-snapshot from READ" "a non-null v"]
   :ensures  ["v is drawn from the admissible basis, OR declares a niche-construction intent if no admissible v discharges the tension"
              ":predicted-discharge = D_v T = g-total of the chosen action"
              "v carries :v-attribution ∈ #{:operator :pilot-autonomous} — the quantity :V5 integrates over"
              "mints :cg-id"]
   :backing  {:status :spike
              :anchor "consent-gate-emit mints cg-id (war_machine_pilot_shapes.clj:54-55); witnessed cg-5b03db29 (claude-1, 2026-05-25)"}}

  {:turn :PRINT
   :geometry "apply v: move along existing ∇, OR deform ∇ (introduce a new typed edge)"
   :gloss    "niche constructed"
   :requires [":cg-id from EVAL"]
   :ensures  ["emits :artefact into a branch (a candidate integral curve γᵢ); execution cites :cg-id"
              "sets :delta-∇? — true iff a new typed-edge family was introduced (see :V4)"
              "a READ false-floor g=:⊥ predicts a ∇-deforming PRINT is the required move (the missing edge family)"]
   :backing  {:status :live-factory
              :anchor "night_shift.clj branch→commit→push→PR path exists; pilot→night-shift hop NOT YET WIRED (the build)"}}

  {:turn :LOOP
   :geometry "p' = φ_ε(p); recompute T; next READ surveys dT_{p'}"
   :gloss    "mana flows"
   :requires ["a completed PRINT"]
   :ensures  ["a scheduler tick advances state and recomputes :judgement"
              ":realised-discharge = the field-change across the tick bracketing the action (e.g. the :ranked-actions-top shift)"
              ":prediction-error = |realised-discharge − predicted-discharge| is logged (see :V3)"]
   :backing  {:status :gap-with-prior-art
              :anchor "tick+re-read witnessed as :ranked-actions-top-shifts-on-action (G −4.99 → −4.39, pilot-inhabitations.edn). LOOP-as-tooling is the primary gap; prior art: E-pattern-mining, M-a-sorry-enterprise"}
   :autonomy
   "INTERACTIVE runs get their learning from operator B→A turns — the operator points the agent at gaps, mines new sorries from the exchange, and judges which patterns applied. That A→B/B→A chain COLLAPSES when the run is non-interactive. So for overnight/full-auto, LOOP must INTERNALISE that learning channel: (1) reread the session transcript + the γ trace; (2) derive/score patterns against futon3/library (M-pattern-application-diagnostic — which patterns applied, which should have); (3) mine new sorries from the run's own interactions (M-a-sorry-enterprise); (4) write them into library/ + the sorry registry so the next READ's dT and the §8 fork-warrant are richer. §8 lets the loop DECIDE autonomously; this :autonomy clause lets it LEARN autonomously — both are required for overnight operation. Lifting M-a-sorry-enterprise + M-pattern-application-diagnostic into LOOP is the next build."}]

 ;; ==========================================================================
 ;; 4. INVARIANTS — the checkable spec. A conforming trace γ satisfies all.
 ;; ==========================================================================
 :invariants
 [{:id :V1-read-completeness
   :plain   "READ shows the slope in every available direction; a missing slope is marked, never silently zero."
   :formal  "∀ a ∈ basis(TpM): dT-snapshot contains (a, g) with g ∈ ℝ ∪ {:⊥}"
   :check   "per READ record: action-basis fully covered; any g=:⊥ is explicit"
   :violation "silent-false-floor — a ∇-gap masquerading as a resolved direction"}

  {:id :V2-no-teleport
   :plain   "No state change without a chosen direction: the AI may not move p→p' unless a v was supplied and recorded."
   :formal  "∀ transition p→p' in γ: ∃ EVAL with non-null v immediately preceding the PRINT that caused it"
   :check   "every PRINT has a preceding EVAL with non-null attributed v; a p→p' with no intervening v is a TELEPORT"
   :violation "teleport — the de-skilling failure mode"
   :is      "the formal statement of the §8.4.2 thesis: skip EVAL and you skip the learning step"}

  {:id :V3-prediction-error-tracked
   :plain   "What actually changed is compared to what EVAL predicted would change."
   :formal  "∀ LOOP: :prediction-error = |:realised-discharge − :predicted-discharge| is recorded"
   :check   "each LOOP carries both predicted (from EVAL) and realised (field-change across the tick); a conforming REPL drives Σ prediction-error down over a session"
   :is      "active-inference belief-update; this is the QUANTITATIVE 'behaviour-matches-spec' signal"
   :calibration "sign/units of realised-discharge (top-G shift vs whole-field ΔG) to be fixed when the verifier is built; the WITNESS exists (G −4.99 → −4.39)"}

  {:id :V4-niche-construction-legible
   :plain   "When an emit creates a capability that did not exist, that is recorded as a change of structure, not hidden inside an ordinary move."
   :formal  "∀ PRINT with :delta-∇? = true: a new typed-edge family is named; dim(TpM) grows for subsequent READs"
   :check   "∇-deforming PRINTs are flagged; the next READ's basis reflects the new edge family"
   :violation "stealth-niche-construction"}

  {:id :V5-skill-is-a-path-integral
   :plain   "Skill accumulated = the sum of directional derivatives the inhabitant actually chose. Autopen and teleports add nothing to operator-skill."
   :formal  "skill_operator(γ) = Σ_{steps : v-attribution = :operator} D_v T ; pilot-autonomous steps and teleports contribute 0"
   :check   "computable over any session trace — makes the de-skilling thesis a measured quantity, not a slogan"
   :is      "re-skilling = forcing traversal; de-skilling/teleportation = endpoint evaluation with no path traversed"}]

