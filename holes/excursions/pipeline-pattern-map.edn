 {:witness/schema
  {:status :partly-satisfied-but-broader-than-snapshots
   :correction
   "This class is attested by Pudding Prover and M-typed-holes as much as by state snapshots. The generic demand is not merely 'emit a snapshot'; it is 'turn mission claims into checkable witnesses/proofs'."
   :library-patterns
   [{:pattern "agent/evidence-over-assertion"
     :fit :primary
     :asks "What evidence anchors this claim, and how can a future agent verify it?"}
    {:pattern "futon-theory/curry-howard-operational"
     :fit :primary
     :asks "What program/proof witnesses that the stated mission/spec can be inhabited?"}
    {:pattern "invariant-coherence/state-snapshot-witness"
     :fit :technical-subcase
     :asks "For long-lived runtime state, what point-in-time projection should be durable queryable evidence?"}
    {:pattern "peripherals/canonical-typed-event-vs-side-channel"
     :fit :supporting
     :asks "If the witness is an event, does it live in the canonical typed event taxonomy rather than a side channel?"}]
   :outside-library-anchors
   ["futon7/holes/C-pudding-prover.md"
    "futon3c/holes/missions/M-typed-holes-*.md"]
   :apparatus
   [{:name "Pudding Prover status/witness guard"
     :path "futon7/holes/C-pudding-prover.md"
